# Copy to .env and set for your environment (e.g. after port-forward).
#
# Option A: Use component vars (passwords URL-encoded automatically; directConnection set for port-forward)
# When port-forwarding to MongoDB, use localhost - in-cluster hostnames only resolve inside the cluster.
# MONGO_USER=root
# MONGO_PASSWORD=your-password
# MONGO_HOST=localhost:27017
# MONGO_DATABASE=fdkHarvestAdmin
# MONGO_AUTH_SOURCE=admin
#
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=fdk_harvest_admin
#
# Option B: Full URIs - use localhost when port-forwarding; add &directConnection=true for replica sets
# MONGO_URI=mongodb://root:admin@localhost:27017/?authSource=admin&directConnection=true
# POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/fdk_harvest_admin
